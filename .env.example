# Azure OpenAI Configuration
VITE_AZURE_OPENAI_API_KEY=your_api_key_here
VITE_AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com
VITE_AZURE_OPENAI_DEPLOYMENT=GPT-5.4
VITE_AZURE_OPENAI_API_VERSION=2024-01-01-preview

# Recommended for server-side runtime (Vercel API functions)
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_OPENAI_DEPLOYMENT=GPT-5.4
AZURE_OPENAI_MODEL=GPT-5.4
AZURE_OPENAI_API_VERSION=2024-01-01-preview

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Frontend API base URL (used by chat widget)
VITE_API_BASE_URL=http://localhost:3001

# Backend CORS allowlist (comma-separated). Required in production.
CORS_ORIGINS=http://localhost:5173
